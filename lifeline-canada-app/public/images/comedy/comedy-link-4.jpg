                      debouncedApply({ gdprApplies: osano.gdprApplies });
                    });

                    osano.addEventListener('osano-cm-consent-changed', () => {
                      debouncedApply({ gdprApplies: osano.gdprApplies });
                    });
                  }
                } catch (error) {
                  console.error('[CMP→GAM] Error initializing with Osano:', error);
                }
              });
            })();     </script><script type="text/javascript" id="osano-cmp-monitor">
