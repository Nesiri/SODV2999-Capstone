":false},{\"languageName\":\"Korean\",\"endonym\":\"한국어\",\"languageCode\":\"ko\",\"ianaCode\":\"ko\",\"isRtl\":false},{\"languageName\":\"Macedonian\",\"endonym\":\"македонски\",\"languageCode\":\"mk\",\"ianaCode\":\"mk\",\"isRtl\":false},{\"languageName\":\"Ukrainian\",\"endonym\":\"Українська\",\"languageCode\":\"uk\",\"ianaCode\":\"uk\",\"isRtl\":false},{\"languageName\":\"Galician\",\"endonym\":\"Galego\",\"languageCode\":\"gl\",\"ianaCode\":\"gl\",\"isRtl\":false},{\"languageName\":\"Northern Kurdish (Kurmanji)\",\"endonym\":\"کورمانجی\",\"languageCode\":\"kmr\",\"ianaCode\":\"ku-kmr\",\"isRtl\":false},{\"languageName\":\"Kurdish (Central)\",\"endonym\":\"کوردی سۆرانی\",\"languageCode\":\"ckb\",\"ianaCode\":\"ku-ckb\",\"isRtl\":true}],\"nativeLanguage\":\"en\",\"isSubtitleRequired\":false,\"resources\":{\"h264\":[{\"bitrate\":1200,\"file\":\"https://py.tedcdn.com/consus/projects/00/19/39/005/products/2013x-kevin-breel-005-fallback-85807f77af2f668869177fc7b9b42e5a-1200k.mp4\"}],\"hls\":{\"adUrl\":\"https://pubads.g.doubleclick.net/gampad/ads?ciu_szs=300x250%2C512x288%2C120x60%2C320x50%2C6x7%2C6x8\\u0026correlator=%5Bcorrelator%5D\\u0026cust_params=event%3DTEDxKids%40Ambleside%26id%3D1830%26tag%3DTEDx%2Cdepression%2Cmental%2Bhealth%2Csuicide%2Cyouth%26talk%3Dkevin_breel_confessions_of_a_depressed_comic%26year%3D2013\\u0026env=vp\\u0026gdfp_req=1\\u0026impl=s\\u0026iu=%2F5641%2Fmobile%2Fios%2Fweb\\u0026output=xml_vast2\\u0026sz=640x360\\u0026unviewed_position_start=1\\u0026url=%5Breferrer%5D\",\"maiTargeting\":{\"id\":\"1830\",\"talk\":\"kevin_breel_confessions_of_a_depressed_comic\",\"tag\":\"TEDx,depression,mental health,suicide,youth\",\"year\":\"2013\",\"event\":\"TEDxKids@Ambleside\"},\"stream\":\"https://hls.ted.com/project_masters/1941/manifest.m3u8?intro_master_id=9294\",\"metadata\":\"https://hls.ted.com/project_masters/1941/metadata.json?intro_master_id=9294\"}},\"targeting\":{\"id\":\"1830\",\"talk\":\"kevin_breel_confessions_of_a_depressed_comic\",\"tag\":\"TEDx,depression,mental health,suicide,youth\",\"year\":\"2013\",\"event\":\"TEDxKids@Ambleside\"},\"canonical\":\"https://www.ted.com/talks/kevin_breel_confessions_of_a_depressed_comic\",\"name\":\"Kevin Breel: Confessions of a depressed comic\",\"title\":\"Confessions of a depressed comic\",\"speaker\":\"Kevin Breel\",\"thumb\":\"https://pi.tedcdn.com/r/talkstar-photos.s3.amazonaws.com/uploads/0db75cad-bcb2-4e5e-8922-93fc63160e7e/KevinBreel_2013X-embed.jpg?quality=89\\u0026w=600\",\"slug\":\"kevin_breel_confessions_of_a_depressed_comic\",\"event\":\"TEDxKids@Ambleside\",\"published\":1380294807,\"external\":{\"service\":\"YouTube\",\"code\":\"-Qe8cR4Jl10\",\"duration\":661.0,\"start_time\":0.0}}","acmePlayerData":"{\"id\":92406,\"mediaIdentifier\":\"2013X Kevin Breel\",\"mediaProjectVersionIdentifier\":null,\"duration\":642,\"languages\":[{\"languageName\":\"Greek\",\"endonym\":\"Ελληνικά\",\"languageCode\":\"el\",\"ianaCode\":\"el\",\"isRtl\":false},{\"languageName\":\"Vietnamese\",\"endonym\":\"Tiếng Việt\",\"languageCode\":\"vi\",\"ianaCode\":\"vi\",\"isRtl\":false},{\"languageName\":\"Catalan\",\"endonym\":\"Català\",\"languageCode\":\"ca\",\"ianaCode\":\"ca\",\"isRtl\":false},{\"languageName\":\"Italian\",\"endonym\":\"Italiano\",\"languageCode\":\"it\",\"ianaCode\":\"it\",\"isRtl\":false},{\"languageName\":\"Arabic\",\"endonym\":\"العربية\",\"languageCode\":\"ar\",\"ianaCode\":\"ar\",\"isRtl\":true},{\"languageName\":\"Portuguese, Brazilian\",\"endonym\":\"Português brasileiro\",\"languageCode\":\"pt-br\",\"ianaCode\":\"pt-BR\",\"isRtl\":false},{\"languageName\":\"Czech\",\"endonym\":\"Čeština\",\"languageCode\":\"cs\",\"ianaCode\":\"cs\",\"isRtl\":false},{\"languageName\":\"Indonesian\",\"endonym\":\"Bahasa Indonesia\",\"languageCode\":\"id\",\"ianaCode\":\"id\",\"isRtl\":false},{\"languageName\":\"Spanish\",\"endonym\":\"Español\",\"languageCode\":\"es\",\"ianaCode\":\"es\",\"isRtl\":false},{\"languageName\":\"Russian\",\"endonym\":\"Русский\",\"languageCode\":\"ru\",\"ianaCode\":\"ru\",\"isRtl\":false},{\"languageName\":\"Dutch\",\"endonym\":\"Nederlands\",\"languageCode\":\"nl\",\"ianaCode\":\"nl\",\"isRtl\":false},{\"languageName\":\"Portuguese\",\"endonym\":\"Português de Portugal\",\"languageCode\":\"pt\",\"ianaCode\":\"pt\",\"isRtl\":false},{\"languageName\":\"Chinese, Traditional\",\"endonym\":\"中文 (繁體)\",\"languageCode\":\"zh-tw\",\"ianaCode\":\"zh-Hant\",\"isRtl\":false},{\"languageName\":\"Turkish\",\"endonym\":\"Türkçe\",\"languageCode\":\"tr\",\"ianaCode\":\"tr\",\"isRtl\":false},{\"languageName\":\"Chinese, Simplified\",\"endonym\":\"中文 (简体)\",\"languageCode\":\"zh-cn\",\"ianaCode\":\"zh-Hans\",\"isRtl\":false},{\"languageName\":\"English\",\"endonym\":\"English\",\"languageCode\":\"en\",\"ianaCode\":\"en\",\"isRtl\":false},{\"languageName\":\"Thai\",\"endonym\":\"ภาษาไทย\",\"languageCode\":\"th\",\"ianaCode\":\"th\",\"isRtl\":false},{\"languageName\":\"Romanian\",\"endonym\":\"Română\",\"languageCode\":\"ro\",\"ianaCode\":\"ro\",\"isRtl\":false},{\"languageName\":\"Polish\",\"endonym\":\"Polski\",\"languageCode\":\"pl\",\"ianaCode\":\"pl\",\"isRtl\":false},{\"languageName\":\"French\",\"endonym\":\"Français\",\"languageCode\":\"fr\",\"ianaCode\":\"fr\",\"isRtl\":false},{\"languageName\":\"Bulgarian\",\"endonym\":\"български\",\"languageCode\":\"bg\",\"ianaCode\":\"bg\",\"isRtl\":false},{\"languageName\":\"Croatian\",\"endonym\":\"Hrvatski\",\"languageCode\":\"hr\",\"ianaCode\":\"hr\",\"isRtl\":false},{\"languageName\":\"German\",\"endonym\":\"Deutsch\",\"languageCode\":\"de\",\"ianaCode\":\"de\",\"isRtl\":false},{\"languageName\":\"Danish\",\"endonym\":\"Dansk\",\"languageCode\":\"da\",\"ianaCode\":\"da\",\"isRtl\":false},{\"languageName\":\"Persian\",\"endonym\":\"فارسى\",\"languageCode\":\"fa\",\"ianaCode\":\"fa\",\"isRtl\":true},{\"languageName\":\"Finnish\",\"endonym\":\"Suomi\",\"languageCode\":\"fi\",\"ianaCode\":\"fi\",\"isRtl\":false},{\"languageName\":\"Hungarian\",\"endonym\":\"Magyar\",\"languageCode\":\"hu\",\"ianaCode\":\"hu\",\"isRtl\":false},{\"languageName\":\"Japanese\",\"endonym\":\"日本語\",\"languageCode\":\"ja\",\"ianaCode\":\"ja\",\"isRtl\":false},{\"languageName\":\"Hebrew\",\"endonym\":\"עברית\",\"languageCode\":\"he\",\"ianaCode\":\"he\",\"isRtl\":true},{\"languageName\":\"Serbian\",\"endonym\":\"Српски, Srpski\",\"languageCode\":\"sr\",\"ianaCode\":\"sr\",\"isRtl\":false},{\"languageName\":\"Albanian\",\"endonym\":\"Shqip\",\"languageCode\":\"sq\",\"ianaCode\":\"sq\",\"isRtl\":false},{\"languageName\":\"Korean\",\"endonym\":\"한국어\",\"languageCode\":\"ko\",\"ianaCode\":\"ko\",\"isRtl\":false},{\"languageName\":\"Macedonian\",\"endonym\":\"македонски\",\"languageCode\":\"mk\",\"ianaCode\":\"mk\",\"isRtl\":false},{\"languageName\":\"Ukrainian\",\"endonym\":\"Українська\",\"languageCode\":\"uk\",\"ianaCode\":\"uk\",\"isRtl\":false},{\"languageName\":\"Galician\",\"endonym\":\"Galego\",\"languageCode\":\"gl\",\"ianaCode\":\"gl\",\"isRtl\":false},{\"languageName\":\"Northern Kurdish (Kurmanji)\",\"endonym\":\"کورمانجی\",\"languageCode\":\"kmr\",\"ianaCode\":\"ku-kmr\",\"isRtl\":false},{\"languageName\":\"Kurdish (Central)\",\"endonym\":\"کوردی سۆرانی\",\"languageCode\":\"ckb\",\"ianaCode\":\"ku-ckb\",\"isRtl\":true}],\"nativeLanguage\":\"en\",\"isSubtitleRequired\":false,\"resources\":{\"h264\":[{\"bitrate\":null,\"file\":\"https://ted-conferences-consus-production.s3.amazonaws.com/consus/projects/00/19/39/005/products/2013x-kevin-breel-005-fallback-85807f77af2f668869177fc7b9b42e5a-1200k.mp4\"}],\"hls\":{\"adUrl\":\"\",\"maiTargeting\":{\"id\":92406,\"talk\":\"kevin_breel_confessions_of_a_depressed_comic\",\"tag\":\"TEDx,depression,mental health,suicide,youth\",\"year\":\"2013\",\"event\":\"TEDxKids@Ambleside\"},\"stream\":\"https://ted-conferences-consus-production.s3.amazonaws.com/consus/projects/00/19/39/005/products/2013x-kevin-breel-005-fallback-85807f77af2f668869177fc7b9b42e5a-1200k.mp4\",\"metadata\":\"https://hls.ted.com/project_masters/1941/metadata.json?intro_master_id=9294\"}},\"targeting\":{\"id\":92406,\"talk\":\"kevin_breel_confessions_of_a_depressed_comic\",\"tag\":\"TEDx,depression,mental health,suicide,youth\",\"year\":\"2013\",\"event\":\"TEDxKids@Ambleside\"},\"canonical\":\"https://hls.ted.com/project_masters/1941/manifest.m3u8?intro_master_id=9294\",\"name\":\"Kevin Breel: Confessions of a depressed comic\",\"title\":\"Confessions of a depressed comic\",\"speaker\":\"Kevin Breel\",\"thumb\":null,\"slug\":\"kevin_breel_confessions_of_a_depressed_comic\",\"event\":\"TEDxKids@Ambleside\",\"published\":1380294807,\"dubbedVideoStreams\":{},\"external\":{\"service\":\"YouTube\",\"code\":\"-Qe8cR4Jl10\",\"duration\":\"661.0\",\"start_time\":\"0.0\"}}","takeaways":{"__typename":"TalkTakeawayConnection","nodes":[{"__typename":"TalkTakeaway","id":"30168","text":"{\"headline\":\"Depression Hides Behind Smiles And Thrives In Silence\",\"body\":\"Depression can exist even when life appears picture-perfect to everyone else. Every 30 seconds, someone in the world dies by suicide linked to depression, yet society still tends to ignore the problem or stigmatize those who suffer. The silence and shame surrounding mental health can make reaching out for help feel impossible. True healing begins when people speak honestly about their struggles and learn to accept themselves fully.\",\"bullets\":[\"Depression often remains invisible, masked by outward success and confidence.\",\"Stigma keeps many people silent and isolated, fearing judgment from others.\",\"Mental health is as real and vital as physical health, yet far less accepted.\",\"Acceptance and openness are the first steps toward recovery and compassion.\",\"Building connection and honesty helps turn pain into hope and resilience.\"]}","talkstarTalkId":1830,"offsetSeconds":0,"ttVersion":2,"active":true}]},"talkExtras":{"__typename":"TalkExtras","learnModules":[{"__typename":"LearnModule","author":"Kevin Breel","blurb":null,"eyebrow":null,"headline":"Boy Meets Depression: Or Life Sucks and Then You Live","imageUrl":"https://pe.tedcdn.com/images/ted/2ff6c8a1bde7c31e82f6323de82058e10f6cbdf6_400x569.jpg","linkUrl":"http://www.amazon.com/Boy-Meets-Depression-Life-Sucks/dp/0553418378/ref=as_li_tf_tl?ie=UTF8\u0026camp=1789\u0026creative=9325\u0026creativeASIN=0520271440\u0026linkCode=as2\u0026tag=teco06-20","published":true,"publisher":"Harmony","status":"APPROVED","type":"BOOK","visibleUrl":null,"year":"2015"}],"takeAction":[],"recommendations":[]},"relatedVideos":[{"__typename":"Video","slug":"ruby_wax_what_s_so_funny_about_mental_illness","id":"1584"},{"__typename":"Video","slug":"jd_schramm_break_the_silence_for_suicide_attempt_survivors","id":"1167"},{"__typename":"Video","slug":"joshua_walters_on_being_just_crazy_enough","id":"1178"}],"speakers":{"__typename":"AcmeSpeakerConnection","nodes":[{"__typename":"AcmeSpeaker","photoUrl":"https://pe.tedcdn.com/images/ted/1ddb303bb51ca1da55cc2f82b4aaf22b551589dc_254x191.jpg","firstname":"Kevin","middlename":"","lastname":"Breel","description":"Comedian, activist","isLive":true,"title":"","whatOthersSay":"If someone in your life suffers from depression, you need to watch this video. If you don't think anyone in your life suffers from depression, you need to watch this video -- because you may not realize it if they do.","whoTheyAre":"Writer, comic and mental health activist Kevin Breel speaks up about depression.","whyListen":"\u003cp\u003eAs a teenager, Kevin Breel almost took his own life. His story, so powerfully told in his viral TEDxYouth Talk, gives voice to an often silent struggle and offers a message of hope. \u003c/p\u003e\u003cp\u003eAs Jack Knox writes in the\u0026nbsp;\u003ca href=\"http://www.timescolonist.com/news/local/jack-knox-standup-guy-talks-openly-about-his-depression-1.337879\" target=\"_blank\"\u003eTimes Colonist\u003c/a\u003e : \u003c/p\u003e\u003cp\u003e\u003cem\u003eHis story, abbreviated, is this: He grew up in Cadboro Bay, a popular kid, fun at parties, English and drama awards, always on the honour roll, captain of the Lambrick Park basketball team when it was ranked No. 1 in the province. Under it all was the other him, the kid who plunged into depression at age 13 when his best friend died in a car crash.\u003c/em\u003e\u003c/p\u003e\u003cp\u003eBreel now speaks out about his own depression, with a mission of helping kids his age realize they\u0026#39;re not alone.\u003c/p\u003e","slug":"kevin_breel"}]},"type":{"__typename":"TypeOfVideo","id":"2","name":"TEDx Talk"},"description":"Kevin Breel didn't look like a depressed kid: team captain, at every party, funny and confident. But he tells the story of the night he realized that -- to save his own life -- he needed to say four simple words.","socialTitle":"Confessions of a depressed comic","internalLanguageCode":"en","commentsEnabled":false,"commentsLoggedInOnly":false,"recordedOn":"2013-05-05","curatorApproved":true,"socialDescription":"Kevin Breel didn't look like a depressed kid: team captain, at every party, funny and confident. But he tells the story of the night he realized that -- to save his own life -- he needed to say four simple words.","partnerName":null,"videoContext":"TEDxKids@Ambleside","audioInternalLanguageCode":"en","language":"en","hasTranslations":true,"featured":true,"customPartnerContent":null,"topics":{"__typename":"TopicConnection","nodes":[{"__typename":"Topic","id":"205","name":"depression","slug":"depression"},{"__typename":"Topic","id":"206","name":"mental health","slug":"mental+health"},{"__typename":"Topic","id":"207","name":"suicide","slug":"suicide"},{"__typename":"Topic","id":"273","name":"TEDx","slug":"tedx"},{"__typename":"Topic","id":"314","name":"youth","slug":"youth"}]},"presenterDisplayName":"Kevin Breel","duration":646,"canonicalUrl":"https://www.ted.com/talks/kevin_breel_confessions_of_a_depressed_comic","viewedCount":5049147,"tedcomPercentage":"0.413","youtubePercentage":"0.23","podcastsPercentage":"0.214","tedappsPercentage":"0.143","publishedAt":"2013-09-27T15:13:27Z","id":"1830","title":"Confessions of a depressed comic","slug":"kevin_breel_confessions_of_a_depressed_comic","primaryImageSet":[{"__typename":"PhotoSize","url":"https://talkstar-photos.s3.amazonaws.com/uploads/8eb8a84c-fd51-4eba-8ca7-076bfb297267/KevinBreel_2013X-stageshot.jpg","aspectRatioName":"4x3"},{"__typename":"PhotoSize","url":"https://talkstar-photos.s3.amazonaws.com/uploads/0db75cad-bcb2-4e5e-8922-93fc63160e7e/KevinBreel_2013X-embed.jpg","aspectRatioName":"16x9"},{"__typename":"PhotoSize","url":"https://talkstar-photos.s3.amazonaws.com/uploads/6f922958-50ab-451d-9642-95d8014bf7c9/KevinBreel_2013X-1350x675.jpg","aspectRatioName":"2x1"}]},"transcriptData":{"translation":{"__typename":"Translation","paragraphs":[{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"For a long time in my life,","time":342},{"__typename":"Cue","text":"I felt like I'd been living two different lives.","time":3101},{"__typename":"Cue","text":"There's the life that everyone sees,","time":7692},{"__typename":"Cue","text":"and then there's the life that only I see.","time":11097},{"__typename":"Cue","text":"And in the life that everyone sees,","time":14804},{"__typename":"Cue","text":"who I am is a friend,","time":17324},{"__typename":"Cue","text":"a son, a brother,","time":19798},{"__typename":"Cue","text":"a stand-up comedian and a teenager.","time":22353},{"__typename":"Cue","text":"That's the life everyone sees.","time":25979},{"__typename":"Cue","text":"If you were to ask my friends and family to describe me,","time":27820},{"__typename":"Cue","text":"that's what they would tell you.","time":29346},{"__typename":"Cue","text":"And that's a huge part of me. That is who I am.","time":31185},{"__typename":"Cue","text":"And if you were to ask me to describe myself,","time":33183},{"__typename":"Cue","text":"I'd probably say some of those same things.","time":35993},{"__typename":"Cue","text":"And I wouldn't be lying,","time":38915},{"__typename":"Cue","text":"but I wouldn't totally be telling you the truth, either,","time":42476},{"__typename":"Cue","text":"because the truth is,","time":46006},{"__typename":"Cue","text":"that's just the life everyone else sees.","time":47533},{"__typename":"Cue","text":"In the life that only I see, who I am,","time":50705},{"__typename":"Cue","text":"who I really am,","time":54468},{"__typename":"Cue","text":"is someone who struggles intensely with depression.","time":56395},{"__typename":"Cue","text":"I have for the last six years of my life,","time":60830},{"__typename":"Cue","text":"and I continue to every day.","time":63507}]},{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"Now, for someone who has never experienced depression","time":68626},{"__typename":"Cue","text":"or doesn't really know what that means,","time":71123},{"__typename":"Cue","text":"that might surprise them to hear,","time":72325},{"__typename":"Cue","text":"because there's this pretty popular misconception","time":73708},{"__typename":"Cue","text":"that depression is just being sad","time":75613},{"__typename":"Cue","text":"when something in your life goes wrong,","time":78360},{"__typename":"Cue","text":"when you break up with your girlfriend,","time":80848},{"__typename":"Cue","text":"when you lose a loved one,","time":82490},{"__typename":"Cue","text":"when you don't get the job you wanted.","time":83881},{"__typename":"Cue","text":"But that's sadness. That's a natural thing.","time":85632},{"__typename":"Cue","text":"That's a natural human emotion.","time":87619},{"__typename":"Cue","text":"Real depression isn't being sad","time":89531},{"__typename":"Cue","text":"when something in your life goes wrong.","time":93729},{"__typename":"Cue","text":"Real depression is being sad","time":96358},{"__typename":"Cue","text":"when everything in your life is going right.","time":98144},{"__typename":"Cue","text":"That's real depression, and that's what I suffer from.","time":101413}]},{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"And to be totally honest,","time":103898},{"__typename":"Cue","text":"that's hard for me to stand up here and say.","time":106023},{"__typename":"Cue","text":"It's hard for me to talk about,","time":108837},{"__typename":"Cue","text":"and it seems to be hard for everyone to talk about,","time":110558},{"__typename":"Cue","text":"so much so that no one's talking about it.","time":113321},{"__typename":"Cue","text":"And no one's talking about depression, but we need to be,","time":115689},{"__typename":"Cue","text":"because right now it's a massive problem.","time":118083},{"__typename":"Cue","text":"It's a massive problem.","time":121825},{"__typename":"Cue","text":"But we don't see it on social media, right?","time":123495},{"__typename":"Cue","text":"We don't see it on Facebook. We don't see it on Twitter.","time":125297},{"__typename":"Cue","text":"We don't see it on the news, because it's not happy,","time":127385},{"__typename":"Cue","text":"it's not fun, it's not light.","time":129207},{"__typename":"Cue","text":"And so because we don't see it, we don't see the severity of it.","time":130836}]},{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"But the severity of it and the seriousness of it is this:","time":134431},{"__typename":"Cue","text":"every 30 seconds,","time":138190},{"__typename":"Cue","text":"every 30 seconds, somewhere,","time":139913},{"__typename":"Cue","text":"someone in the world takes their own life","time":142117},{"__typename":"Cue","text":"because of depression,","time":144310},{"__typename":"Cue","text":"and it might be two blocks away, it might be two countries away,","time":145387},{"__typename":"Cue","text":"it might be two continents away, but it's happening,","time":147627},{"__typename":"Cue","text":"and it's happening every single day.","time":149157},{"__typename":"Cue","text":"And we have a tendency, as a society,","time":151727},{"__typename":"Cue","text":"to look at that and go, \"So what?\"","time":154691},{"__typename":"Cue","text":"So what? We look at that, and we go, \"That's your problem.","time":159937},{"__typename":"Cue","text":"That's their problem.\"","time":164592},{"__typename":"Cue","text":"We say we're sad and we say we're sorry,","time":166995},{"__typename":"Cue","text":"but we also say, \"So what?\"","time":168847}]},{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"Well, two years ago it was my problem,","time":170224},{"__typename":"Cue","text":"because I sat on the edge of my bed","time":174907},{"__typename":"Cue","text":"where I'd sat a million times before","time":178964},{"__typename":"Cue","text":"and I was suicidal.","time":182324},{"__typename":"Cue","text":"I was suicidal, and if you were to look at my life on the surface,","time":185140},{"__typename":"Cue","text":"you wouldn't see a kid who was suicidal.","time":189066},{"__typename":"Cue","text":"You'd see a kid who was the captain of his basketball team,","time":191308},{"__typename":"Cue","text":"the drama and theater student of the year,","time":193424},{"__typename":"Cue","text":"the English student of the year,","time":195485},{"__typename":"Cue","text":"someone who was consistently on the honor roll","time":196444},{"__typename":"Cue","text":"and consistently at every party.","time":198272},{"__typename":"Cue","text":"So you would say I wasn't depressed, you would say","time":201945},{"__typename":"Cue","text":"I wasn't suicidal, but you would be wrong.","time":203586},{"__typename":"Cue","text":"You would be wrong. So I sat there that night","time":206297},{"__typename":"Cue","text":"beside a bottle of pills with a pen and paper in my hand","time":207736},{"__typename":"Cue","text":"and I thought about taking my own life","time":211774},{"__typename":"Cue","text":"and I came this close to doing it.","time":213762},{"__typename":"Cue","text":"I came this close to doing it.","time":217114}]},{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"And I didn't, so that makes me one of the lucky ones,","time":218796},{"__typename":"Cue","text":"one of the people who gets to step out on the ledge","time":221924},{"__typename":"Cue","text":"and look down but not jump,","time":224059},{"__typename":"Cue","text":"one of the lucky ones who survives.","time":226320},{"__typename":"Cue","text":"Well, I survived, and that just leaves me with my story,","time":228325},{"__typename":"Cue","text":"and my story is this:","time":230722},{"__typename":"Cue","text":"In four simple words, I suffer from depression.","time":233127},{"__typename":"Cue","text":"I suffer from depression,","time":236480},{"__typename":"Cue","text":"and for a long time, I think,","time":238910},{"__typename":"Cue","text":"I was living two totally different lives,","time":246230},{"__typename":"Cue","text":"where one person was always afraid of the other.","time":248826},{"__typename":"Cue","text":"I was afraid that people would see me for who I really was,","time":250687},{"__typename":"Cue","text":"that I wasn't the perfect, popular kid in high school everyone thought I was,","time":252786},{"__typename":"Cue","text":"that beneath my smile, there was struggle,","time":256028},{"__typename":"Cue","text":"and beneath my light, there was dark,","time":258453},{"__typename":"Cue","text":"and beneath my big personality just hid even bigger pain.","time":260416}]},{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"See, some people might fear girls not liking them back.","time":264793},{"__typename":"Cue","text":"Some people might fear sharks. Some people might fear death.","time":267430},{"__typename":"Cue","text":"But for me, for a large part of my life, I feared myself.","time":269519},{"__typename":"Cue","text":"I feared my truth, I feared my honesty, I feared my vulnerability,","time":274212},{"__typename":"Cue","text":"and that fear made me feel","time":276904},{"__typename":"Cue","text":"like I was forced into a corner,","time":279126},{"__typename":"Cue","text":"like I was forced into a corner and there was only one way out,","time":281483},{"__typename":"Cue","text":"and so I thought about that way every single day.","time":284513},{"__typename":"Cue","text":"I thought about it every single day,","time":288306},{"__typename":"Cue","text":"and if I'm being totally honest, standing here","time":289753},{"__typename":"Cue","text":"I've thought about it again since, because that's the sickness,","time":291424},{"__typename":"Cue","text":"that's the struggle, that's depression,","time":294797},{"__typename":"Cue","text":"and depression isn't chicken pox.","time":296731},{"__typename":"Cue","text":"You don't beat it once and it's gone forever.","time":297950},{"__typename":"Cue","text":"It's something you live with. It's something you live in.","time":299668},{"__typename":"Cue","text":"It's the roommate you can't kick out. It's the voice you can't ignore.","time":302431},{"__typename":"Cue","text":"It's the feelings you can't seem to escape,","time":306003},{"__typename":"Cue","text":"the scariest part is that after a while,","time":308264},{"__typename":"Cue","text":"you become numb to it. It becomes normal for you,","time":313337},{"__typename":"Cue","text":"and what you really fear the most","time":316217},{"__typename":"Cue","text":"isn't the suffering inside of you.","time":318504},{"__typename":"Cue","text":"It's the stigma inside of others,","time":321360},{"__typename":"Cue","text":"it's the shame, it's the embarrassment,","time":322876},{"__typename":"Cue","text":"it's the disapproving look on a friend's face,","time":325157},{"__typename":"Cue","text":"it's the whispers in the hallway that you're weak,","time":327610},{"__typename":"Cue","text":"it's the comments that you're crazy.","time":331074},{"__typename":"Cue","text":"That's what keeps you from getting help.","time":332475},{"__typename":"Cue","text":"That's what makes you hold it in and hide it.","time":334575},{"__typename":"Cue","text":"It's the stigma. So you hold it in and you hide it,","time":337569},{"__typename":"Cue","text":"and you hold it in and you hide it,","time":339904},{"__typename":"Cue","text":"and even though it's keeping you in bed every day","time":341766},{"__typename":"Cue","text":"and it's making your life feel empty no matter how much you try and fill it,","time":343442},{"__typename":"Cue","text":"you hide it, because the stigma in our society","time":346382},{"__typename":"Cue","text":"around depression is very real.","time":348545},{"__typename":"Cue","text":"It's very real, and if you think that it isn't, ask yourself this:","time":351460},{"__typename":"Cue","text":"Would you rather make your next Facebook status","time":354662},{"__typename":"Cue","text":"say you're having a tough time getting out of bed","time":356471},{"__typename":"Cue","text":"because you hurt your back","time":358217},{"__typename":"Cue","text":"or you're having a tough time getting out of bed every morning","time":360366},{"__typename":"Cue","text":"because you're depressed?","time":362358},{"__typename":"Cue","text":"That's the stigma, because unfortunately,","time":364458},{"__typename":"Cue","text":"we live in a world where if you break your arm,","time":366742},{"__typename":"Cue","text":"everyone runs over to sign your cast,","time":369210},{"__typename":"Cue","text":"but if you tell people you're depressed, everyone runs the other way.","time":371899},{"__typename":"Cue","text":"That's the stigma.","time":374700},{"__typename":"Cue","text":"We are so, so, so accepting of any body part breaking down","time":377200},{"__typename":"Cue","text":"other than our brains. And that's ignorance.","time":382166},{"__typename":"Cue","text":"That's pure ignorance, and that ignorance has created","time":385268},{"__typename":"Cue","text":"a world that doesn't understand depression,","time":387280},{"__typename":"Cue","text":"that doesn't understand mental health.","time":388844},{"__typename":"Cue","text":"And that's ironic to me, because depression","time":391350},{"__typename":"Cue","text":"is one of the best documented problems we have in the world,","time":393303},{"__typename":"Cue","text":"yet it's one of the least discussed.","time":395813},{"__typename":"Cue","text":"We just push it aside and put it in a corner","time":397858},{"__typename":"Cue","text":"and pretend it's not there and hope it'll fix itself.","time":400294}]},{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"Well, it won't. It hasn't, and it's not going to,","time":403881},{"__typename":"Cue","text":"because that's wishful thinking,","time":407223},{"__typename":"Cue","text":"and wishful thinking isn't a game plan, it's procrastination,","time":409114},{"__typename":"Cue","text":"and we can't procrastinate on something this important.","time":411887},{"__typename":"Cue","text":"The first step in solving any problem","time":416816},{"__typename":"Cue","text":"is recognizing there is one.","time":420207},{"__typename":"Cue","text":"Well, we haven't done that, so we can't really expect","time":421690},{"__typename":"Cue","text":"to find an answer when we're still afraid of the question.","time":424448}]},{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"And I don't know what the solution is.","time":427633},{"__typename":"Cue","text":"I wish I did, but I don't -- but I think,","time":431412},{"__typename":"Cue","text":"I think it has to start here.","time":433873},{"__typename":"Cue","text":"It has to start with me, it has to start with you,","time":435881},{"__typename":"Cue","text":"it has to start with the people who are suffering,","time":438280},{"__typename":"Cue","text":"the ones who are hidden in the shadows.","time":441698},{"__typename":"Cue","text":"We need to speak up and shatter the silence.","time":443115},{"__typename":"Cue","text":"We need to be the ones who are brave for what we believe in,","time":445115},{"__typename":"Cue","text":"because if there's one thing that I've come to realize,","time":447434},{"__typename":"Cue","text":"if there's one thing that I see as the biggest problem,","time":450609},{"__typename":"Cue","text":"it's not in building a world","time":454185},{"__typename":"Cue","text":"where we eliminate the ignorance of others.","time":457224},{"__typename":"Cue","text":"It's in building a world where we teach the acceptance of ourselves,","time":460973},{"__typename":"Cue","text":"where we're okay with who we are,","time":464259},{"__typename":"Cue","text":"because when we get honest,","time":465460},{"__typename":"Cue","text":"we see that we all struggle and we all suffer.","time":466960},{"__typename":"Cue","text":"Whether it's with this, whether it's with something else,","time":469756},{"__typename":"Cue","text":"we all know what it is to hurt.","time":471708},{"__typename":"Cue","text":"We all know what it is to have pain in our heart,","time":474535},{"__typename":"Cue","text":"and we all know how important it is to heal.","time":476373},{"__typename":"Cue","text":"But right now, depression is society's deep cut","time":479067},{"__typename":"Cue","text":"that we're content to put a Band-Aid over and pretend it's not there.","time":482461}]},{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"Well, it is there. It is there, and you know what? It's okay.","time":485022},{"__typename":"Cue","text":"Depression is okay. If you're going through it, know that you're okay.","time":489526},{"__typename":"Cue","text":"And know that you're sick, you're not weak,","time":493337},{"__typename":"Cue","text":"and it's an issue, not an identity,","time":495999},{"__typename":"Cue","text":"because when you get past the fear and the ridicule","time":497935},{"__typename":"Cue","text":"and the judgment and the stigma of others,","time":500688},{"__typename":"Cue","text":"you can see depression for what it really is,","time":502485},{"__typename":"Cue","text":"and that's just a part of life,","time":505471},{"__typename":"Cue","text":"just a part of life, and as much as I hate,","time":507710},{"__typename":"Cue","text":"as much as I hate some of the places,","time":511438},{"__typename":"Cue","text":"some of the parts of my life depression has dragged me down to,","time":513917},{"__typename":"Cue","text":"in a lot of ways I'm grateful for it.","time":517013},{"__typename":"Cue","text":"Because yeah, it's put me in the valleys,","time":519548},{"__typename":"Cue","text":"but only to show me there's peaks,","time":521360},{"__typename":"Cue","text":"and yeah it's dragged me through the dark","time":522792},{"__typename":"Cue","text":"but only to remind me there is light.","time":524391},{"__typename":"Cue","text":"My pain, more than anything in 19 years on this planet,","time":526977},{"__typename":"Cue","text":"has given me perspective, and my hurt,","time":530720},{"__typename":"Cue","text":"my hurt has forced me to have hope,","time":532979},{"__typename":"Cue","text":"have hope and to have faith, faith in myself,","time":535474},{"__typename":"Cue","text":"faith in others, faith that it can get better,","time":538005},{"__typename":"Cue","text":"that we can change this, that we can speak up","time":540550},{"__typename":"Cue","text":"and speak out and fight back against ignorance,","time":542628},{"__typename":"Cue","text":"fight back against intolerance,","time":545386},{"__typename":"Cue","text":"and more than anything,","time":547975},{"__typename":"Cue","text":"learn to love ourselves,","time":549990},{"__typename":"Cue","text":"learn to accept ourselves for who we are,","time":552716},{"__typename":"Cue","text":"the people we are, not the people the world wants us to be.","time":554895},{"__typename":"Cue","text":"Because the world I believe in is one","time":558990},{"__typename":"Cue","text":"where embracing your light doesn't mean ignoring your dark.","time":560602},{"__typename":"Cue","text":"The world I believe in is one where we're measured","time":564770},{"__typename":"Cue","text":"by our ability to overcome adversities, not avoid them.","time":566851},{"__typename":"Cue","text":"The world I believe in is one where I can look someone in the eye","time":571367},{"__typename":"Cue","text":"and say, \"I'm going through hell,\"","time":575591},{"__typename":"Cue","text":"and they can look back at me and go, \"Me too,\" and that's okay,","time":577353},{"__typename":"Cue","text":"and it's okay because depression is okay. We're people.","time":580930},{"__typename":"Cue","text":"We're people, and we struggle and we suffer","time":584632},{"__typename":"Cue","text":"and we bleed and we cry, and if you think that true strength","time":587062},{"__typename":"Cue","text":"means never showing any weakness, then I'm here","time":589790},{"__typename":"Cue","text":"to tell you you're wrong.","time":591909},{"__typename":"Cue","text":"You're wrong, because it's the opposite.","time":595155},{"__typename":"Cue","text":"We're people, and we have problems.","time":599052},{"__typename":"Cue","text":"We're not perfect, and that's okay.","time":601736}]},{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"So we need to stop the ignorance,","time":603407},{"__typename":"Cue","text":"stop the intolerance, stop the stigma,","time":605621},{"__typename":"Cue","text":"and stop the silence, and we need to take away the taboos,","time":608699},{"__typename":"Cue","text":"take a look at the truth, and start talking,","time":613273},{"__typename":"Cue","text":"because the only way we're going to beat a problem","time":617812},{"__typename":"Cue","text":"that people are battling alone","time":622536},{"__typename":"Cue","text":"is by standing strong together,","time":625870},{"__typename":"Cue","text":"by standing strong together.","time":629633}]},{"__typename":"Paragraph","cues":[{"__typename":"Cue","text":"And I believe that we can.","time":633397},{"__typename":"Cue","text":"I believe that we can. Thank you guys so much.","time":636376},{"__typename":"Cue","text":"This is a dream come true. Thank you. (Applause)","time":638295},{"__typename":"Cue","text":"Thank you. (Applause)","time":640702}]}],"id":"60830","language":{"__typename":"AcmeLanguage","id":"35","endonym":"English","englishName":"English","internalLanguageCode":"en","rtl":false},"reviewer":null,"translator":null},"video":{"__typename":"Video","id":"1830","talkExtras":{"__typename":"TalkExtras","footnotes":[]}}},"playlistData":null,"commentsEnabled":false,"commentsLoggedInOnly":false,"shouldShowTranscript":false,"shouldShowTakeaway":false,"preview":false},"__N_SSP":true},"page":"/talks/[...slug]","query":{"language":"en","slug":["kevin_breel_confessions_of_a_depressed_comic"]},"buildId":"9dd252a30561","isFallback":false,"isExperimentalCompile":false,"dynamicIds":[575315,717286],"gssp":true,"scriptLoader":[]}</script></body></html>