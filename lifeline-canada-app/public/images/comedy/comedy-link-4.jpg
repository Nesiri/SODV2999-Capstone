            window.addEventListener('load', () => {
                // Get query parameters using URLSearchParams
                const getQueryParams = () => {
                    const urlParams = new URLSearchParams(window.location.search);
                    const params = {};
                    urlParams.forEach((value, key) => {
                        params[key] = value;
                    });
                    return params;
                };

                // Check for verification cookie
                const getCookie = (name) => {
                    const value = '; ' + document.cookie;
                    const parts = value.split('; ' + name + '=');
                    if (parts.length === 2) return parts.pop().split(';').shift();
                    return null;
                };

                // Delete verification cookie
                const deleteVerificationCookie = () => {
                    document.cookie = 'ted_gv=; expires=Thu, 01 Jan 1970 00:00:00 UTC; path=/; secure';
                };

                const query = getQueryParams();
                const hasUTM_ID = query.utm_id && query.utm_id.length > 0;
                const language = navigator.language.slice(0, 2);

                const verificationCookie = getCookie('ted_gv');              
                const test_gv = getCookie('test-cookie');
                const hasVerificationCookie = verificationCookie === '1' || test_gv === '1';              
               
                const config = {
                    hostWebsiteType: "spa",
                    customerId: 'a107d7f43ad64daa9a7ef2f8bfde9d97',
                    isCustom: true,
                    autoTrackPageview: false,
                    useStoredTags: true
                };

                // Build overlayKeyValue with all relevant parameters
                const overlayKeyValue = {
                    navigator_language: language
                };

                if (hasUTM_ID) {
                    overlayKeyValue.utm_id = query.utm_id;
                }

                // Add get_verified flag if verification cookie is present
                if (hasVerificationCookie) {
                    overlayKeyValue.get_verified = "true";

                    deleteVerificationCookie();
                }

                config.overlayKeyValue = overlayKeyValue;                     

                // Check if Sailthru is available (may be blocked by ad blockers)
                if (typeof Sailthru !== 'undefined') {
                    Sailthru.init(config);
                }
            });
        </script><script id="__NEXT_DATA__" type="application/json">{"props":{"pageProps":{"shortenedUrl":"https://go.ted.com/evp9s","action":null,"videoData":{"__typename":"Video","playerData":"{\"id\":\"1830\",\"mediaIdentifier\":\"consus-pm1941-im9294\",\"mediaProjectVersionIdentifier\":\"consus-pm1941-im9294\",\"duration\":642,\"languages\":[{\"languageName\":\"Greek\",\"endonym\":\"Ελληνικά\",\"languageCode\":\"el\",\"ianaCode\":\"el\",\"isRtl\":false},{\"languageName\":\"Vietnamese\",\"endonym\":\"Tiếng Việt\",\"languageCode\":\"vi\",\"ianaCode\":\"vi\",\"isRtl\":false},{\"languageName\":\"Catalan\",\"endonym\":\"Català\",\"languageCode\":\"ca\",\"ianaCode\":\"ca\",\"isRtl\":false},{\"languageName\":\"Italian\",\"endonym\":\"Italiano\",\"languageCode\":\"it\",\"ianaCode\":\"it\",\"isRtl\":false},{\"languageName\":\"Arabic\",\"endonym\":\"العربية\",\"languageCode\":\"ar\",\"ianaCode\":\"ar\",\"isRtl\":true},{\"languageName\":\"Portuguese, Brazilian\",\"endonym\":\"Português brasileiro\",\"languageCode\":\"pt-br\",\"ianaCode\":\"pt-BR\",\"isRtl\":false},{\"languageName\":\"Czech\",\"endonym\":\"Čeština\",\"languageCode\":\"cs\",\"ianaCode\":\"cs\",\"isRtl\":false},{\"languageName\":\"Indonesian\",\"endonym\":\"Bahasa Indonesia\",\"languageCode\":\"id\",\"ianaCode\":\"id\",\"isRtl\":false},{\"languageName\":\"Spanish\",\"endonym\":\"Español\",\"languageCode\":\"es\",\"ianaCode\":\"es\",\"isRtl\":false},{\"languageName\":\"Russian\",\"endonym\":\"Русский\",\"languageCode\":\"ru\",\"ianaCode\":\"ru\",\"isRtl\":false},{\"languageName\":\"Dutch\",\"endonym\":\"Nederlands\",\"languageCode\":\"nl\",\"ianaCode\":\"nl\",\"isRtl\":false},{\"languageName\":\"Portuguese\",\"endonym\":\"Português de Portugal\",\"languageCode\":\"pt\",\"ianaCode\":\"pt\",\"isRtl\":false},{\"languageName\":\"Chinese, Traditional\",\"endonym\":\"中文 (繁體)\",\"languageCode\":\"zh-tw\",\"ianaCode\":\"zh-Hant\",\"isRtl\":false},{\"languageName\":\"Turkish\",\"endonym\":\"Türkçe\",\"languageCode\":\"