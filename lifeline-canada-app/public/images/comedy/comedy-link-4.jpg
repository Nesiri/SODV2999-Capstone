                  script.crossOrigin = 'anonymous';
                  script.onload = resolve;
                  script.onerror = reject;
                  document.head.appendChild(script);
                });
              }

              function debounce(fn, ms = 50) {
                let timer;
                return function(...args) {
                  clearTimeout(timer);
                  timer = setTimeout(() => fn(...args), ms);
                };
              }

              // --- Initialize GPT stub ---
              window.googletag = window.googletag || { cmd: [] };

              let gptLoaded = false;
              let gptServicesEnabled = false;

              // --- PPID: hash _ted_user_id for GAM audience targeting ---
              function getTedUserId() {
                var match = document.cookie.match(/(?:^|; )_ted_user_id=([^;]*)/);
                return match ? decodeURIComponent(match[1]) : null;
              }

              async function sha256Hex(str) {
                var data = new TextEncoder().encode(str);
                var hash = await crypto.subtle.digest('SHA-256', data);
                return Array.from(new Uint8Array(hash)).map(function(b) { return b.toString(16).padStart(2, '0'); }).join('');
              }

              var _ppidCache = null;
              var _ppidUserId = null;

              async function applyPPID(consentGranted) {
                try {
                  var pubads = window.googletag && window.googletag.pubads ? window.googletag.pubads() : null;
                  if (!pubads || !pubads.setPublisherProvidedId) return;

                  var userId = getTedUserId();
                  if (!consentGranted || !userId) {
                    pubads.setPublisherProvidedId('');
                    _ppidCache = null;
                    _ppidUserId = null;
                    return;
                  }

                  if (userId === _ppidUserId && _ppidCache) {
                    pubads.setPublisherProvidedId(_ppidCache);
                    return;
                  }

                  var hashed = await sha256Hex(userId);
                  _ppidCache = hashed;
                  _ppidUserId = userId;
                  pubads.setPublisherProvidedId(hashed);
