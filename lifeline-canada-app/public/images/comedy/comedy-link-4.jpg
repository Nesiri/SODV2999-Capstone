                      console.warn('[CMP→GAM] Error getting Osano consent:', e);
                    }

                    // Osano returns 'ACCEPT' or 'DENY' strings
                    const doNotSell = consent['OPT_OUT'] === 'DENY' || consent['OPT-OUT'] === 'DENY';
                    const allowPersonalization = consent['PERSONALIZATION'] === 'ACCEPT';
                    const allowMarketing = consent['MARKETING'] === 'ACCEPT';
                    const allowAnalytics = consent['ANALYTICS'] === 'ACCEPT';

                    // US opt-out model: if user hasn't made a choice, default to granted
                    // Only deny if explicitly denied or GPC is active
                    const hasExplicitChoice = Object.keys(consent).length > 0;

                    const ad_personalization = (doNotSell || gpc || (hasExplicitChoice && !allowPersonalization)) ? 'denied' : 'granted';
                    const ad_user_data = (doNotSell || gpc || (hasExplicitChoice && !allowMarketing)) ? 'denied' : 'granted';
                    const ad_storage = (doNotSell || gpc || (hasExplicitChoice && !allowMarketing)) ? 'denied' : 'granted';
                    const analytics_storage = (hasExplicitChoice && !allowAnalytics) ? 'denied' : 'granted';

                    gtag('consent', 'update', {
                      ad_personalization,
                      ad_user_data,
                      ad_storage,
                      analytics_storage
                    });

                    ppidConsentGranted = ad_user_data === 'granted';
                  }

                  // Load GPT after consent is determined
                  await ensureGPT();

                  // Enable services once (GPTScript component will handle detailed config)
                  if (!gptServicesEnabled) {
                    window.googletag.cmd.push(function() {
                      try {
                        // Note: GPTScript component handles enableSingleRequest and enableServices
                        // This is just a fallback to ensure services are enabled
                        if (window.googletag.pubads && !window.gptServicesEnabled) {
                          // IMPORTANT: Do NOT call enableSingleRequest() for SPA applications
                          // SRA (Single Request Architecture) batches all slot requests into ONE request
                          // but in SPAs, slots are defined dynamically after enableServices() is called.
                          // Without SRA, each slot can be fetched individually via refresh().
                          // window.googletag.pubads().enableSingleRequest(); // DISABLED for SPA

                          // Disable initial load - we'll manually call display() + refresh() for each slot
                          window.googletag.pubads().disableInitialLoad();

                          // PPID must be set BEFORE enableServices or first ad request won't include it
                          // Use .finally() so enableServices always fires even if PPID hash fails
                          applyPPID(ppidConsentGranted).finally(function() {
                            window.googletag.enableServices();
                            window.gptServicesEnabled = true;
                            gptServicesEnabled = true;
                            console.info('[CMP→GAM] GPT services enabled (SPA mode - no SRA)');
                            // Fetch ads for slots registered during disableInitialLoad
                            var pubads = window.googletag.pubads();
                            var slots = pubads.getSlots();
                            if (slots && slots.length > 0) {
                              pubads.refresh(slots);
                            }
                          });
                        }
                      } catch (error) {
                        console.error('[CMP→GAM] Error enabling GPT services:', error);
                      }
                    });
                  } else {
                    // Consent changed after initial enable — update PPID and refresh slots
                    window.googletag.cmd.push(function() {
                      try {
                        applyPPID(ppidConsentGranted);
                        const pubads = window.googletag.pubads();
                        if (pubads && pubads.getSlots) {
                          const slots = pubads.getSlots();
                          if (slots && slots.length > 0) {
                            pubads.refresh(slots);
                          }
                        }
                      } catch (error) {
                        console.error('[CMP→GAM] Error refreshing slots:', error);
                      }
                    });
                  }
                } catch (error) {
                  console.error('[CMP→GAM] applyConsentFromOsano error:', error);
                }
              }

              // Debounce only for subsequent consent changes, not initial load
              const debouncedApply = debounce(applyConsentFromOsano, 50);

              // --- Wire into Osano using onInitialized event (per Osano support recommendation) ---
              // This ensures consent state is fully established before any ad requests,
              // while maintaining async loading for performance.
              window.Osano('onInitialized', function(consent) {
                try {
                  console.info('[CMP→GAM] Osano initialized with consent:', consent);

                  // Get initial consent state
                  const osano = window.Osano.cm;
                  const initialState = {
                    gdprApplies: osano.gdprApplies
                  };

                  // Apply immediately for initial load (no debounce for faster ad loading)
                  applyConsentFromOsano(initialState);

                  // Listen for consent changes (debounced to prevent rapid-fire calls)
                  if (osano.addEventListener) {
